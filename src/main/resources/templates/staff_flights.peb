<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Flight Scheduler</title>
  <style>
    :root{
      --bg0:#0b0d12;
      --bg1:#101420;
      --card:#0f1320;
      --line:rgba(255,255,255,.10);
      --muted:rgba(255,255,255,.70);
      --muted2:rgba(255,255,255,.55);
      --text:#ffffff;
      --accent:#3f5efb;
      --accent2:#38bdf8;
      --danger:#ff4d4d;
      --shadow:0 20px 60px rgba(0,0,0,.45);
      --radius:18px;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
      color:var(--text);
      background: radial-gradient(1200px 800px at 20% 20%, rgba(63,94,251,.18), transparent 60%),
                  radial-gradient(900px 600px at 90% 10%, rgba(56,189,248,.12), transparent 55%),
                  linear-gradient(180deg, var(--bg0), var(--bg1));
      min-height:100vh;
    }
    .wrap{max-width:1200px;margin:0 auto;padding:26px 18px 40px;}
    .topbar{
      display:flex;align-items:center;justify-content:space-between;gap:14px;
      padding:16px 18px;border-radius:18px;
      background: rgba(15,19,32,.55);
      border:1px solid rgba(255,255,255,.10);
      backdrop-filter: blur(10px);
      box-shadow: 0 14px 40px rgba(0,0,0,.35);
    }
    .brand{display:flex;align-items:center;gap:12px;font-weight:800;letter-spacing:.2px;}
    .badge{
      width:34px;height:34px;border-radius:10px;display:grid;place-items:center;
      background:rgba(255,255,255,.08);
      border:1px solid rgba(255,255,255,.10);
      box-shadow: 0 12px 30px rgba(0,0,0,.25);
      font-size:16px;
    }
    .nav{
      display:flex;gap:10px;flex-wrap:wrap;align-items:center;justify-content:flex-end;
    }
    .link{
      padding:10px 12px;border-radius:14px;
      border:1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.06);
      color: rgba(255,255,255,.9);
      text-decoration:none;
      font-weight:700;
      transition:.18s ease;
      cursor:pointer;
    }
    .link:hover{ background: rgba(255,255,255,.10); transform: translateY(-1px); }
    .link.red{
      border-color: rgba(255,77,77,.28);
      background: rgba(255,77,77,.12);
    }
    h1{
      margin:22px 4px 8px;
      font-size:36px;
      letter-spacing:-.6px;
    }
    .sub{
      margin:0 4px 18px;
      color: var(--muted);
      line-height:1.6;
      font-size:14px;
    }
    .grid{
      display:grid;
      grid-template-columns: 420px 1fr;
      gap:16px;
    }
    .card{
      border-radius:var(--radius);
      background: rgba(15,19,32,.85);
      border:1px solid rgba(255,255,255,.10);
      box-shadow: var(--shadow);
      padding:18px;
    }
    .card h2{
      margin:0 0 8px;
      font-size:18px;
      letter-spacing:-.2px;
    }
    label{
      display:block;
      margin:12px 0 8px;
      color: rgba(255,255,255,.78);
      font-size:13px;
      font-weight:700;
    }
    .input, select{
      width:100%;
      padding:12px 12px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.14);
      background: rgba(10,12,18,.55);
      color: white;
      outline:none;
      font-size:14px;
      transition:.18s ease;
    }
    .input:focus, select:focus{
      border-color: rgba(63,94,251,.65);
      box-shadow: 0 0 0 4px rgba(63,94,251,.18);
    }
    .row2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
    .btn{
      width:100%;
      padding:12px 12px;
      border:none;
      border-radius:14px;
      background: linear-gradient(90deg, var(--accent), #2b7bff);
      color:white;
      font-weight:900;
      font-size:14px;
      cursor:pointer;
      transition:.18s ease;
      margin-top:14px;
    }
    .btn:hover{ filter:brightness(1.05); transform: translateY(-1px); }
    .btn:active{ transform: translateY(0px); }
    .btn2{
      width:100%;
      padding:12px 12px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.14);
      background: rgba(255,255,255,.06);
      color: rgba(255,255,255,.92);
      font-weight:800;
      cursor:pointer;
      margin-top:10px;
      transition:.18s ease;
    }
    .btn2:hover{ background: rgba(255,255,255,.10); transform: translateY(-1px); }
    .msg{
      margin:0 0 12px;
      padding:12px 12px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.06);
      color: rgba(255,255,255,.90);
      font-size:13px;
      line-height:1.35;
    }
    .msg.err{
      background: rgba(255,77,77,.12);
      border-color: rgba(255,77,77,.25);
      color: #ffd0d0;
    }
    table{
      width:100%;
      border-collapse:separate;
      border-spacing:0 10px;
    }
    th{
      text-align:left;
      font-size:12px;
      color: rgba(255,255,255,.65);
      font-weight:800;
      padding:0 10px 6px;
      letter-spacing:.4px;
    }
    td{
      padding:12px 10px;
      background: rgba(15,19,32,.55);
      border-top:1px solid rgba(255,255,255,.10);
      border-bottom:1px solid rgba(255,255,255,.10);
      font-size:14px;
      color: rgba(255,255,255,.92);
    }
    tr td:first-child{
      border-left:1px solid rgba(255,255,255,.10);
      border-top-left-radius:14px;
      border-bottom-left-radius:14px;
    }
    tr td:last-child{
      border-right:1px solid rgba(255,255,255,.10);
      border-top-right-radius:14px;
      border-bottom-right-radius:14px;
    }
    .pill{
      display:inline-flex;align-items:center;gap:8px;
      padding:6px 10px;border-radius:999px;
      border:1px solid rgba(255,255,255,.14);
      background: rgba(255,255,255,.06);
      font-size:12px;
      color: rgba(255,255,255,.85);
      font-weight:800;
    }
    .actions{display:flex;gap:8px;flex-wrap:wrap;}
    .a{
      display:inline-flex;align-items:center;justify-content:center;
      padding:9px 10px;border-radius:12px;
      border:1px solid rgba(255,255,255,.14);
      background: rgba(255,255,255,.06);
      color: rgba(255,255,255,.92);
      text-decoration:none;
      font-weight:900;
      font-size:12px;
      cursor:pointer;
      transition:.18s ease;
    }
    .a:hover{ background: rgba(255,255,255,.10); transform: translateY(-1px); }
    .a.red{
      border-color: rgba(255,77,77,.30);
      background: rgba(255,77,77,.10);
    }
    @media (max-width: 980px){
      .grid{ grid-template-columns:1fr; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="topbar">
      <div class="brand">
        <div class="badge">✈</div>
        <div>SkyFlow Staff</div>
      </div>
      <div class="nav">
        <a class="link" href="/staff/dashboard">Dashboard</a >
        <a class="link red" href="/staff/logout">Logout</a >
      </div>
    </div>

    <h1>Flight Scheduler</h1>
    <p class="sub">Create, edit, and manage flights directly from the database.</p >

    <div class="grid">
      <div class="card">
        {% if error and error != "" %}
          <div class="msg err">{{ error }}</div>
        {% endif %}
        {% if ok and ok != "" %}
          <div class="msg">{{ ok }}</div>
        {% endif %}

        {% if editId and editId != 0 %}
          <h2>Edit Flight #{{ editId }}</h2>
          <form action="/staff/flights/update" method="post">
            <input type="hidden" name="id" value="{{ editId }}"/>

            <label for="flightNumber">Flight Number</label>
            <input class="input" id="flightNumber" name="flightNumber" value="{{ editFlight.flightNumber }}" placeholder="e.g. 101"/>

            <div class="row2">
              <div>
                <label for="originId">Origin</label>
                <select id="originId" name="originId" required>
                  {% for a in airports %}
                    <option value="{{ a.id }}" {% if editFlight.originId == a.id %}selected{% endif %}>
                      {{ a.iata }} {{ a.name }}
                    </option>
                  {% endfor %}
                </select>
              </div>
              <div>
                <label for="destId">Destination</label>
                <select id="destId" name="destId" required>
                  {% for a in airports %}
                    <option value="{{ a.id }}" {% if editFlight.destId == a.id %}selected{% endif %}>
                      {{ a.iata }} {{ a.name }}
                    </option>
                  {% endfor %}
                </select>
              </div>
            </div>

            <label for="dep">Scheduled Departure Time</label>
            <input class="input" id="dep" name="dep" value="{{ editFlight.dep }}" placeholder="YYYY-MM-DD HH:MM:SS"/>

            <label for="arr">Scheduled Arrival Time</label>
            <input class="input" id="arr" name="arr" value="{{ editFlight.arr }}" placeholder="YYYY-MM-DD HH:MM:SS"/>

            <div class="row2">
              <div>
                <label for="status">Status</label>
                <select id="status" name="status">
                  <option value="scheduled" {% if editFlight.status == "scheduled" %}selected{% endif %}>scheduled</option>
                  <option value="delayed" {% if editFlight.status == "delayed" %}selected{% endif %}>delayed</option>
                  <option value="departed" {% if editFlight.status == "departed" %}selected{% endif %}>departed</option>
                  <option value="arrived" {% if editFlight.status == "arrived" %}selected{% endif %}>arrived</option>
                  <option value="cancelled" {% if editFlight.status == "cancelled" %}selected{% endif %}>cancelled</option>
                </select>
              </div>
              <div>
                <label for="capacity">Capacity</label>
                <input class="input" id="capacity" name="capacity" value="{{ editFlight.capacity }}" placeholder="e.g. 180"/>
              </div>
            </div>

            <button class="btn" type="submit">Save Changes</button>
            <a class="a" style="margin-top:10px;width:100%;justify-content:center;" href="/staff/flights">Cancel Editing</a >
          </form>
        {% else %}
          <h2>Create New Flight</h2>
          <form action="/staff/flights/create" method="post">
            <label for="flightNumber">Flight Number</label>
            <input class="input" id="flightNumber" name="flightNumber" placeholder="e.g. 101"/>

            <div class="row2">
              <div>
                <label for="originId">Origin</label>
                <select id="originId" name="originId" required>
                  {% for a in airports %}
                    <option value="{{ a.id }}">{{ a.iata }} {{ a.name }}</option>
                  {% endfor %}
                </select>
              </div>
              <div>
                <label for="destId">Destination</label>
                <select id="destId" name="destId" required>
                  {% for a in airports %}
                    <option value="{{ a.id }}">{{ a.iata }} {{ a.name }}</option>
                  {% endfor %}
                </select>
              </div>
            </div>

            <label for="dep">Scheduled Departure Time</label>
            <input class="input" id="dep" name="dep" placeholder="YYYY-MM-DD HH:MM:SS"/>

            <label for="arr">Scheduled Arrival Time</label>
            <input class="input" id="arr" name="arr" placeholder="YYYY-MM-DD HH:MM:SS"/>

            <div class="row2">
              <div>
                <label for="status">Status</label>
                <select id="status" name="status">
                  <option value="scheduled" selected>scheduled</option>
                  <option value="delayed">delayed</option>
                  <option value="departed">departed</option>
                  <option value="arrived">arrived</option>
                  <option value="cancelled">cancelled</option>
                </select>
              </div>
              <div>
                <label for="capacity">Capacity</label>
                <input class="input" id="capacity" name="capacity" placeholder="e.g. 180"/>
              </div>
            </div>

            <button class="btn" type="submit">Create Flight</button>
          </form>
        {% endif %}
      </div>

      <div class="card">
        <h2>Flights</h2>
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>No.</th>
              <th>Route</th>
              <th>Departure</th>
              <th>Arrival</th>
              <th>Status</th>
              <th>Cap.</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for f in flights %}
              <tr>
                <td>{{ f.id }}</td>
                <td><span class="pill">{{ f.flightNumber }}</span></td>
                <td>{{ f.originIata }} → {{ f.destIata }}</td>
                <td>{{ f.dep }}</td>
                <td>{{ f.arr }}</td>
                <td>{{ f.status }}</td>
                <td>{{ f.capacity }}</td>
                <td>
                  <div class="actions">
                    <a class="a" href="/staff/flights?edit={{ f.id }}">Edit</a >
                    <form action="/staff/flights/delete" method="post" style="margin:0;">
                      <input type="hidden" name="id" value="{{ f.id }}"/>
                      <button class="a red" type="submit">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</body>
</html>