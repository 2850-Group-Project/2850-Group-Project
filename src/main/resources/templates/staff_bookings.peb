<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Bookings - SkyFlow Staff</title>
  <style>
    :root{
      --bg0:#0b0d12;
      --bg1:#101420;
      --card:#0f1320;
      --line:rgba(255,255,255,.10);
      --muted:rgba(255,255,255,.70);
      --muted2:rgba(255,255,255,.55);
      --text:#ffffff;
      --accent:#3f5efb;
      --accent2:#38bdf8;
      --danger:#ff4d4d;
      --shadow:0 20px 60px rgba(0,0,0,.45);
      --radius:18px;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
      color:var(--text);
      background: radial-gradient(1200px 800px at 20% 20%, rgba(63,94,251,.18), transparent 60%),
                  radial-gradient(900px 600px at 90% 10%, rgba(56,189,248,.12), transparent 55%),
                  linear-gradient(180deg, var(--bg0), var(--bg1));
      min-height:100vh;
    }
    .wrap{
      max-width:1200px;
      margin:0 auto;
      padding:26px 18px 60px;
    }
    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:14px;
      margin-bottom:18px;
    }
    .brand{
      display:flex;
      align-items:center;
      gap:12px;
      font-weight:800;
      letter-spacing:.2px;
      opacity:.95;
    }
    .brand-badge{
      width:34px;height:34px;
      border-radius:10px;
      display:grid;place-items:center;
      background:rgba(255,255,255,.08);
      border:1px solid rgba(255,255,255,.10);
      box-shadow: 0 12px 30px rgba(0,0,0,.25);
      font-size:16px;
    }
    .right{
      display:flex;
      align-items:center;
      gap:10px;
      color:var(--muted);
      font-size:13px;
    }
    .link{
      color: rgba(125,211,252,.95);
      text-decoration:none;
      font-weight:700;
    }
    .link:hover{ text-decoration:underline; }
    .grid{
      display:grid;
      grid-template-columns: 1fr;
      gap:16px;
    }
    .card{
      border-radius:var(--radius);
      background: rgba(15,19,32,.90);
      border:1px solid rgba(255,255,255,.10);
      box-shadow: var(--shadow);
      padding:18px;
    }
    h1{
      margin:0;
      font-size:22px;
      letter-spacing:-.3px;
    }
    .sub{
      margin:6px 0 0;
      color:var(--muted);
      font-size:13px;
      line-height:1.45;
    }
    .section-title{
      display:flex;
      align-items:end;
      justify-content:space-between;
      gap:12px;
      margin-bottom:12px;
    }
    .table{
      width:100%;
      border-collapse:collapse;
      overflow:hidden;
      border-radius:16px;
      border:1px solid rgba(255,255,255,.10);
    }
    .table th, .table td{
      padding:12px 10px;
      border-bottom:1px solid rgba(255,255,255,.08);
      vertical-align:top;
      text-align:left;
      font-size:13px;
    }
    .table th{
      color:rgba(255,255,255,.80);
      font-weight:800;
      font-size:12px;
      letter-spacing:.35px;
      background: rgba(255,255,255,.04);
      text-transform:uppercase;
    }
    .muted{ color:var(--muted2); }
    .pill{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:7px 10px;
      border-radius:999px;
      background:rgba(255,255,255,.10);
      border:1px solid rgba(255,255,255,.12);
      color:rgba(255,255,255,.88);
      font-size:12px;
      width:fit-content;
      white-space:nowrap;
    }
    .input, select{
      width:100%;
      padding:10px 12px;
      border-radius:12px;
      border:1px solid rgba(255,255,255,.14);
      background: rgba(10,12,18,.55);
      color: white;
      outline:none;
      font-size:13px;
      transition:.18s ease;
    }
    .input:focus, select:focus{
      border-color: rgba(63,94,251,.65);
      box-shadow: 0 0 0 4px rgba(63,94,251,.18);
    }
    .btn{
      border:1px solid rgba(255,255,255,.14);
      background: rgba(255,255,255,.06);
      color: rgba(255,255,255,.92);
      padding:10px 12px;
      border-radius:12px;
      font-weight:800;
      cursor:pointer;
      transition: .18s ease;
      user-select:none;
      width:100%;
    }
    .btn:hover{ background: rgba(255,255,255,.10); transform: translateY(-1px); }
    .btn:active{ transform: translateY(0px); }
    .primary{
      background: linear-gradient(90deg, var(--accent), #2b7bff);
      border:none;
    }
    .primary:hover{ filter:brightness(1.05); }
    .row{
      display:grid;
      grid-template-columns: 1.2fr 1fr 1fr 1fr .8fr;
      gap:10px;
      align-items:end;
    }
    @media (max-width: 980px){
      .row{ grid-template-columns: 1fr; }
      .table{ display:block; overflow:auto; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="topbar">
      <div class="brand">
        <div class="brand-badge">✈</div>
        <div>SkyFlow Staff</div>
      </div>
      <div class="right">
        <span class="pill">{{ staffName }} • {{ staffRole }}</span>
        <a class="link" href="/staff/dashboard">Dashboard</a >
        <span class="muted">•</span>
        <a class="link" href="/staff/logout">Logout</a >
      </div>
    </div>

    <div class="grid">
      <div class="card">
        <div class="section-title">
          <div>
            <h1>Bookings</h1>
            <p class="sub">Manage bookings, assign flights and seats. Seat list is filtered by the selected flight.</p >
          </div>
        </div>

        <form action="/staff/bookings/create" method="post">
          <div class="row">
            <div>
              <label class="muted" style="display:block;margin:0 0 6px;font-weight:800;font-size:12px;letter-spacing:.35px;text-transform:uppercase;">Passenger Email</label>
              <input class="input" type="email" name="passengerEmail" required placeholder="passenger@example.com" />
            </div>
            <div>
              <label class="muted" style="display:block;margin:0 0 6px;font-weight:800;font-size:12px;letter-spacing:.35px;text-transform:uppercase;">First Name</label>
              <input class="input" type="text" name="passengerFirstName" placeholder="First name" />
            </div>
            <div>
              <label class="muted" style="display:block;margin:0 0 6px;font-weight:800;font-size:12px;letter-spacing:.35px;text-transform:uppercase;">Last Name</label>
              <input class="input" type="text" name="passengerLastName" placeholder="Last name" />
            </div>
            <div>
              <label class="muted" style="display:block;margin:0 0 6px;font-weight:800;font-size:12px;letter-spacing:.35px;text-transform:uppercase;">Flight</label>
              <select name="flightId" required>
                <option value="">Select flight</option>
                {% for f in flights %}
                  <option value="{{ f.id }}">{{ f.label }}</option>
                {% endfor %}
              </select>
            </div>
            <div>
              <label class="muted" style="display:block;margin:0 0 6px;font-weight:800;font-size:12px;letter-spacing:.35px;text-transform:uppercase;">Status</label>
              <select name="bookingStatus" required>
                <option value="pending">pending</option>
                <option value="confirmed">confirmed</option>
                <option value="cancelled">cancelled</option>
              </select>
            </div>
          </div>

          <div style="margin-top:10px; display:grid; grid-template-columns: 1fr 220px; gap:10px; align-items:end;">
            <div>
              <label class="muted" style="display:block;margin:0 0 6px;font-weight:800;font-size:12px;letter-spacing:.35px;text-transform:uppercase;">Seat (optional, must match flight)</label>
              <select name="seatId">
                <option value="">No seat</option>
              </select>
              <div class="sub" style="margin-top:8px;">After creating, edit the booking to assign a seat for its flight.</div>
            </div>
            <div>
              <button class="btn primary" type="submit">Create Booking →</button>
            </div>
          </div>
        </form>
      </div>

      <div class="card">
        <div class="section-title">
          <div>
            <h1>Existing Bookings</h1>
            <p class="sub">Update status, flight, and seat. If you change flight, seat will reset and must be re-selected.</p >
          </div>
        </div>

        <table class="table">
          <thead>
            <tr>
              <th>Booking</th>
              <th>Passenger</th>
              <th>Status</th>
              <th>Flight</th>
              <th>Seat</th>
              <th style="width:120px;">Action</th>
            </tr>
          </thead>
          <tbody>
            {% if bookings is empty %}
              <tr>
                <td colspan="6" class="muted">No bookings found.</td>
              </tr>
            {% else %}
              {% for b in bookings %}
                <tr>
                  <td>
                    <div style="font-weight:900;">{{ b.bookingReference }}</div>
                    <div class="muted" style="margin-top:3px;">ID: {{ b.bookingId }}</div>
                    <div class="muted" style="margin-top:3px;">{{ b.createdAt }}</div>
                  </td>

                  <td>
                    <div style="font-weight:800;">{% if b.passengerName %}{{ b.passengerName }}{% else %}—{% endif %}</div>
                    <div class="muted" style="margin-top:3px;">{% if b.passengerEmail %}{{ b.passengerEmail }}{% else %}—{% endif %}</div>
                  </td>

                  <td colspan="3">
                    <form action="/staff/bookings/update" method="post" style="display:grid; grid-template-columns: 1fr 1fr 1fr; gap:10px;">
                      <input type="hidden" name="bookingId" value="{{ b.bookingId }}" />

                      <div>
                        <label class="muted" style="display:block;margin:0 0 6px;font-weight:800;font-size:11px;letter-spacing:.35px;text-transform:uppercase;">Status</label>
                        <select name="bookingStatus">
                          <option value="pending" {% if b.bookingStatus == "pending" %}selected{% endif %}>pending</option>
                          <option value="confirmed" {% if b.bookingStatus == "confirmed" %}selected{% endif %}>confirmed</option>
                          <option value="cancelled" {% if b.bookingStatus == "cancelled" %}selected{% endif %}>cancelled</option>
                        </select>
                      </div>

                      <div>
                        <label class="muted" style="display:block;margin:0 0 6px;font-weight:800;font-size:11px;letter-spacing:.35px;text-transform:uppercase;">Flight</label>
                        <select name="flightId">
                          <option value="">No flight</option>
                          {% for f in flights %}
                            <option value="{{ f.id }}"
                              {% if b.flightId is not null and f.id == b.flightId %}selected{% endif %}>
                              {{ f.label }}
                            </option>
                          {% endfor %}
                        </select>
                      </div>

                      <div>
                        <label class="muted" style="display:block;margin:0 0 6px;font-weight:800;font-size:11px;letter-spacing:.35px;text-transform:uppercase;">Seat</label>
                        <select name="seatId">
                          <option value="">No seat</option>

                          {% if b.flightId is not null %}
                            {% set fid = b.flightId %}
                            {% set seats = seatsByFlight[fid] %}
                            {% if seats is not empty %}
                              {% for s in seats %}
                                {% set isCurrent = false %}
                                {% if b.seatId is not empty %}
                                  {% if ("" ~ s.id) == ("" ~ b.seatId) %}
                                    {% set isCurrent = true %}
                                  {% endif %}
                                {% endif %}

                                {% if s.status == "available" or isCurrent %}
                                  <option value="{{ s.id }}"
                                    {% if isCurrent %}selected{% endif %}>
                                    {{ s.seatCode }}{% if s.status != "available" %} (assigned){% endif %}
                                  </option>
                                {% endif %}
                              {% endfor %}
                            {% endif %}
                          {% endif %}
                        </select>
                        <div class="muted" style="margin-top:6px;font-size:12px;">
                          Current: {% if b.seatCode %}{{ b.seatCode }}{% else %}no seat{% endif %}
                        </div>
                      </div>

                      <div style="grid-column: 1 / -1; display:grid; grid-template-columns: 1fr 140px; gap:10px; margin-top:10px;">
                        <div class="muted" style="font-size:12px; align-self:center;">
                          Saving seat only works if it belongs to the selected flight.
                        </div>
                        <button class="btn primary" type="submit">Save</button>
                      </div>
                    </form>
                  </td>

                  <td>
                    <div class="pill">{% if b.bookingStatus %}{{ b.bookingStatus }}{% else %}—{% endif %}</div>
                  </td>
                </tr>
              {% endfor %}
            {% endif %}
          </tbody>
        </table>
      </div>

    </div>
  </div>
</body>
</html>