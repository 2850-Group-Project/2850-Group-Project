<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SkyBook — Find Your Flight</title>
  <style>
    :root {
      --bg0: #0b0d12;
      --bg1: #101420;
      --panel: #0f1320;
      --panel2: #0c1020;
      --line: rgba(255,255,255,.10);
      --muted: rgba(255,255,255,.70);
      --muted2: rgba(255,255,255,.55);
      --text: #ffffff;
      --accent: #3f5efb;
      --accent2: #38bdf8;
      --good: #22c55e;
      --warn: #f59e0b;
      --bad: #ef4444;
      --shadow: 0 18px 50px rgba(0,0,0,.45);
      --radius: 18px;
      --radius2: 14px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }

    body {
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
      color: var(--text);
      background:
        radial-gradient(1200px 800px at 20% 20%, rgba(63,94,251,.16), transparent 60%),
        radial-gradient(900px 650px at 85% 10%, rgba(56,189,248,.10), transparent 55%),
        linear-gradient(180deg, var(--bg0), var(--bg1));
      min-height: 100vh;
    }

    /* ── NAV ── */
    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 40px;
      border-bottom: 1px solid rgba(255,255,255,.06);
      background: rgba(10,12,18,.35);
      backdrop-filter: blur(10px);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      color: var(--text);
    }
    .brand-badge {
      width: 34px; height: 34px;
      border-radius: 12px;
      display: grid; place-items: center;
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(255,255,255,.12);
      box-shadow: 0 12px 28px rgba(0,0,0,.25);
      font-size: 16px;
    }
    .brand-title {
      font-weight: 800;
      letter-spacing: .2px;
      font-size: 15px;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .nav-links a {
      text-decoration: none;
      color: rgba(255,255,255,.75);
      padding: 8px 14px;
      border-radius: 12px;
      font-size: 13px;
      transition: .18s ease;
      border: 1px solid transparent;
    }
    .nav-links a:hover {
      background: rgba(255,255,255,.06);
      border-color: rgba(255,255,255,.08);
    }

    .nav-right {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .btn-ghost {
      padding: 9px 16px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.04);
      color: rgba(255,255,255,.80);
      font-size: 13px;
      cursor: pointer;
      text-decoration: none;
      transition: .18s ease;
    }
    .btn-ghost:hover { background: rgba(255,255,255,.08); }

    .btn-primary {
      padding: 9px 18px;
      border-radius: 12px;
      border: none;
      background: linear-gradient(135deg, var(--accent), #5b7afc);
      color: white;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      text-decoration: none;
      transition: .18s ease;
      box-shadow: 0 4px 18px rgba(63,94,251,.35);
    }
    .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 24px rgba(63,94,251,.45); }

    /* ── HERO ── */
    .hero {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 80px 24px 60px;
      text-align: center;
    }

    .hero h1 {
      font-size: clamp(36px, 6vw, 64px);
      font-weight: 900;
      letter-spacing: -1.5px;
      line-height: 1.2;
      height: fit-content;
      margin-bottom: 40px;
      max-width: 750px;
    }

    .hero h1 span {
      background: linear-gradient(135deg, var(--accent2), var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      display: inline-block;
      padding-bottom: 4px;
    }

    .hero p {
      color: var(--muted2);
      font-size: 16px;
      line-height: 1.6;
      max-width: 480px;
      margin-bottom: 40px;
    }

    /* ── SEARCH CARD ── */
    .search-card {
      width: 100%;
      max-width: 1000px;
      background: rgba(15,19,32,.85);
      border: 1px solid rgba(255,255,255,.10);
      border-radius: 22px;
      box-shadow: var(--shadow);
      padding: 24px;
      backdrop-filter: blur(12px);
    }

    .trip-tabs {
      display: flex;
      gap: 6px;
      margin-bottom: 20px;
    }
    .trip-tab {
      padding: 7px 16px;
      border-radius: 10px;
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.03);
      color: rgba(255,255,255,.60);
      font-size: 13px;
      cursor: pointer;
      transition: .18s ease;
    }
    .trip-tab.active {
      background: rgba(63,94,251,.18);
      border-color: rgba(63,94,251,.40);
      color: white;
      font-weight: 600;
    }

    .search-form {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr 1fr auto;
      gap: 10px;
      align-items: end;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .field label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .7px;
      color: rgba(255,255,255,.45);
      text-transform: uppercase;
      padding-left: 2px;
    }
    .field-inner {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 11px 13px;
      border-radius: var(--radius2);
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.04);
      transition: .18s ease;
    }
    .field-inner:focus-within {
      border-color: rgba(63,94,251,.45);
      background: rgba(63,94,251,.07);
    }
    .field-inner .ico {
      font-size: 14px;
      opacity: .65;
      flex-shrink: 0;
    }
    .field-inner input,
    .field-inner select {
      width: 100%;
      border: none;
      outline: none;
      background: transparent;
      color: white;
      font-size: 13px;
      font-family: inherit;
    }
    .field-inner select option {
      background: var(--panel);
      color: white;
    }

    .swap-btn {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .swap-btn button {
      width: 34px; height: 34px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.06);
      color: rgba(255,255,255,.70);
      font-size: 16px;
      cursor: pointer;
      display: grid; place-items: center;
      transition: .18s ease;
      margin-top: 22px;
    }
    .swap-btn button:hover { background: rgba(255,255,255,.12); transform: rotate(180deg); }

    .search-row {
      display: grid;
      grid-template-columns: 1fr 34px 1fr 1fr 1fr auto;
      gap: 10px;
      align-items: center;
    }

    .btn-search {
      padding: 12px 28px;
      border-radius: var(--radius2);
      border: none;
      background: linear-gradient(135deg, var(--accent), #5b7afc);
      color: white;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: .18s ease;
      box-shadow: 0 4px 18px rgba(63,94,251,.35);
      white-space: nowrap;
      height: 46px;
    }
    .btn-search:hover { transform: translateY(-1px); box-shadow: 0 6px 24px rgba(63,94,251,.45); }

    /* ── PASSENGERS DROPDOWN ── */
    .pax-wrapper {
      position: relative;
    }
    .pax-display {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 11px 13px;
      border-radius: var(--radius2);
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.04);
      cursor: pointer;
      transition: .18s ease;
      user-select: none;
    }
    .pax-display:hover { border-color: rgba(63,94,251,.45); background: rgba(63,94,251,.07); }
    .pax-display .ico { font-size: 14px; opacity: .65; }
    .pax-display span { font-size: 13px; color: white; flex: 1; }
    .pax-display .caret { font-size: 10px; opacity: .5; }

    .pax-dropdown {
      display: none;
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      right: 0;
      background: rgba(12,16,32,.98);
      border: 1px solid rgba(255,255,255,.12);
      border-radius: var(--radius2);
      box-shadow: 0 20px 50px rgba(0,0,0,.6);
      padding: 14px;
      z-index: 50;
      min-width: 220px;
    }
    .pax-dropdown.open { display: block; }

    .pax-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 8px 0;
      border-bottom: 1px solid rgba(255,255,255,.06);
    }
    .pax-row:last-child { border-bottom: none; }
    .pax-label { font-size: 13px; color: rgba(255,255,255,.80); }
    .pax-sub { font-size: 11px; color: rgba(255,255,255,.40); }
    .pax-ctrl {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .pax-ctrl button {
      width: 28px; height: 28px;
      border-radius: 8px;
      border: 1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.06);
      color: white;
      font-size: 16px;
      cursor: pointer;
      display: grid; place-items: center;
      transition: .18s ease;
      line-height: 1;
    }
    .pax-ctrl button:hover { background: rgba(255,255,255,.12); }
    .pax-ctrl .count { font-size: 14px; font-weight: 700; min-width: 18px; text-align: center; }

    /* ── STATS ── */
    .stats {
      display: flex;
      gap: 32px;
      margin-top: 36px;
      flex-wrap: wrap;
      justify-content: center;
    }
    .stat { text-align: center; }
    .stat b { display: block; font-size: 22px; font-weight: 900; letter-spacing: -.5px; }
    .stat span { font-size: 12px; color: var(--muted2); margin-top: 2px; display: block; }

    /* ── POPULAR ROUTES ── */
    .section {
      max-width: 940px;
      margin: 0 auto;
      padding: 0 24px 60px;
    }
    .section-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 16px;
    }
    .section-header h2 { font-size: 18px; font-weight: 800; letter-spacing: -.3px; }
    .section-header a { font-size: 13px; color: var(--accent2); text-decoration: none; }
    .section-header a:hover { text-decoration: underline; }

    .routes {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }

    .route-card {
      border-radius: var(--radius);
      background: rgba(15,19,32,.75);
      border: 1px solid rgba(255,255,255,.10);
      box-shadow: var(--shadow);
      padding: 16px;
      cursor: pointer;
      text-decoration: none;
      color: var(--text);
      display: flex;
      flex-direction: column;
      gap: 10px;
      transition: .18s ease;
    }
    .route-card:hover {
      transform: translateY(-2px);
      border-color: rgba(63,94,251,.30);
      background: rgba(63,94,251,.08);
    }
    .route-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .route-airports {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 18px;
      font-weight: 900;
      letter-spacing: -.3px;
    }
    .route-arrow { color: var(--accent2); font-size: 14px; }
    .route-price {
      text-align: right;
    }
    .route-price b { font-size: 18px; font-weight: 900; color: var(--good); }
    .route-price span { display: block; font-size: 11px; color: var(--muted2); }
    .route-cities { font-size: 12px; color: var(--muted2); }

    /* ── FOOTER ── */
    footer {
      border-top: 1px solid rgba(255,255,255,.06);
      padding: 20px 40px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: rgba(255,255,255,.40);
      font-size: 12px;
      flex-wrap: wrap;
      gap: 10px;
    }
    footer a { color: rgba(255,255,255,.50); text-decoration: none; }
    footer a:hover { text-decoration: underline; }
    .footer-links { display: flex; gap: 16px; }

    @media (max-width: 860px) {
      .search-row { grid-template-columns: 1fr 1fr; }
      .swap-btn { display: none; }
      .routes { grid-template-columns: 1fr; }
      nav { padding: 14px 20px; }
      .nav-links { display: none; }
    }


    /* remove the ugly scroll bar */
    * {
      scrollbar-width: none; /* Firefox */
    }

    *::-webkit-scrollbar {
      display: none; /* Chrome, Safari, Edge */
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav>
    <a href="/" class="brand">
      <div class="brand-badge">✈️</div>
      <span class="brand-title">SkyFlow</span>
    </a>

    <div class="nav-right">
      <a href="/profile/bookings" class="btn-ghost">My Bookings</a>
      <a href="/profile" class="btn-primary">{{ userSession.firstName }}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <h1>Where we flying to,<br /><span>gooner?</span></h1>

    <!-- SEARCH CARD -->
    <div class="search-card">

      <!-- Trip type tabs -->
      <div class="trip-tabs">
        <button class="trip-tab active" onclick="setTripType('return', this)">⇄ Return</button>
        <button class="trip-tab" onclick="setTripType('oneway', this)">→ One way</button>
      </div>

      <!-- Form -->
      <form action="/flights/search" method="GET" id="searchForm">
        <input type="hidden" name="trip_type" id="tripType" value="return" />

        <div class="search-row">

          <!-- Origin -->
          <div class="field">
            <label>From</label>
            <div class="field-inner">
              <input
                type="text"
                name="origin"
                placeholder="City or airport"
                autocomplete="off"
                required
              />
            </div>
          </div>

          <!-- Swap -->
          <div class="swap-btn">
            <button type="button" onclick="swapAirports()" title="Swap airports">⇄</button>
          </div>

          <!-- Destination -->
          <div class="field">
            <label>To</label>
            <div class="field-inner">
              <input
                type="text"
                name="destination"
                placeholder="City or airport"
                autocomplete="off"
                required
              />
            </div>
          </div>

          <!-- Departure date -->
          <div class="field">
            <label>Departure</label>
            <div class="field-inner">
              <input type="date" name="departure_date" required />
            </div>
          </div>

          <!-- Return date -->
          <div class="field" id="returnField">
            <label>Return</label>
            <div class="field-inner">
              <input type="date" name="return_date" id="returnDate" />
            </div>
          </div>

          <!-- Passengers -->
          <div class="field pax-wrapper">
            <label>Passengers</label>
            <div class="pax-display" onclick="togglePax()">
              <span id="paxLabel">1 Adult</span>
              <span class="caret">▼</span>
            </div>
            <div class="pax-dropdown" id="paxDropdown">
              <div class="pax-row">
                <div>
                  <div class="pax-label">Adults</div>
                  <div class="pax-sub">16+ years</div>
                </div>
                <div class="pax-ctrl">
                  <button type="button" onclick="changePax('adults', -1)">−</button>
                  <span class="count" id="adultsCount">1</span>
                  <button type="button" onclick="changePax('adults', 1)">+</button>
                </div>
              </div>
              <div class="pax-row">
                <div>
                  <div class="pax-label">Children</div>
                  <div class="pax-sub">2-15 years</div>
                </div>
                <div class="pax-ctrl">
                  <button type="button" onclick="changePax('children', -1)">−</button>
                  <span class="count" id="childrenCount">0</span>
                  <button type="button" onclick="changePax('children', 1)">+</button>
                </div>
              </div>
              <div class="pax-row">
                <div>
                  <div class="pax-label">Infants</div>
                  <div class="pax-sub">Under 2 years</div>
                </div>
                <div class="pax-ctrl">
                  <button type="button" onclick="changePax('infants', -1)">−</button>
                  <span class="count" id="infantsCount">0</span>
                  <button type="button" onclick="changePax('infants', 1)">+</button>
                </div>
              </div>
            </div>
            <!-- Hidden inputs submitted with form -->
            <input type="hidden" name="adults" id="adultsInput" value="1" />
            <input type="hidden" name="children" id="childrenInput" value="0" />
            <input type="hidden" name="infants" id="infantsInput" value="0" />
          </div>

          <!-- Search button -->
          <div>
            <button type="submit" class="btn-search">Search flights</button>
          </div>

        </div>
      </form>
    </div>

  <!-- FOOTER -->
  <footer>
    <span>© 2026 SkyBook. All rights reserved lol</span>
    <div class="footer-links">
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="/help">Help</a>
      <a href="/complaints">Complaints</a>
    </div>
  </footer>

  <script>
    // ── Trip type toggle ──
    function setTripType(type, btn) {
      document.querySelectorAll('.trip-tab').forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('tripType').value = type;
      const returnField = document.getElementById('returnField');
      const returnDate = document.getElementById('returnDate');
      if (type === 'oneway') {
        returnField.style.display = 'none';
        returnDate.removeAttribute('required');
      } else {
        returnField.style.display = '';
        returnDate.setAttribute('required', '');
      }
    }

    // ── Swap airports ──
    function swapAirports() {
      const inputs = document.querySelectorAll('input[name="origin"], input[name="destination"]');
      const tmp = inputs[0].value;
      inputs[0].value = inputs[1].value;
      inputs[1].value = tmp;
    }

    // ── Passengers ──
    const pax = { adults: 1, children: 0, infants: 0 };

    function togglePax() {
      document.getElementById('paxDropdown').classList.toggle('open');
    }

    document.addEventListener('click', e => {
      if (!e.target.closest('.pax-wrapper')) {
        document.getElementById('paxDropdown').classList.remove('open');
      }
    });

    function changePax(type, delta) {
      const min = type === 'adults' ? 1 : 0;
      pax[type] = Math.max(min, Math.min(9, pax[type] + delta));
      document.getElementById(type + 'Count').textContent = pax[type];
      document.getElementById(type + 'Input').value = pax[type];
      updatePaxLabel();
    }

    function updatePaxLabel() {
      const total = pax.adults + pax.children + pax.infants;
      const parts = [];
      if (pax.adults) parts.push(`${pax.adults} Adult${pax.adults > 1 ? 's' : ''}`);
      if (pax.children) parts.push(`${pax.children} Child${pax.children > 1 ? 'ren' : ''}`);
      if (pax.infants) parts.push(`${pax.infants} Infant${pax.infants > 1 ? 's' : ''}`);
      document.getElementById('paxLabel').textContent = parts.join(', ');
    }

    // Set min date to today
    const today = new Date().toISOString().split('T')[0];
    document.querySelectorAll('input[type="date"]').forEach(i => i.setAttribute('min', today));
  </script>

</body>
</html>